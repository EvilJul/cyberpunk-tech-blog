# JWT 配置
# 生产环境必须设置！使用至少 32 个字符的随机字符串
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-32-character-secret-key-change-this-in-production
JWT_EXPIRES_IN=1h

# Node 环境
NODE_ENV=development

# 服务器端口
PUBLIC_PORT=9098
ADMIN_PORT=3033

# CORS 配置（逗号分隔多个来源）
CORS_ORIGIN=http://localhost:9099,http://localhost:3033

# Vite 基础路径（用于子路径部署）
VITE_BASE_PATH=/
